# ---------------------------------------------------------------------------
# Remote (HTTP) MCP server config -- used by server_http.py ONLY.
# The local stdio server (mcp_server.py / Claude Code) ignores all of this.
#
# Copy to .env for local testing. On Render, set these as Environment Variables
# in the dashboard instead of committing a .env file.
# ---------------------------------------------------------------------------

# Public HTTPS URL of THIS server (its own resource identifier).
# Locally you can leave it as the localhost URL; on Render use the real one.
MCP_PUBLIC_URL=https://your-app.onrender.com

# Your OAuth provider (Authorization Server). Must support Dynamic Client
# Registration so claude.ai can register itself. Examples:
#   Auth0:   https://YOUR_TENANT.us.auth0.com
#   Stytch:  https://YOUR_PROJECT.customers.stytch.com
#   Descope: https://api.descope.com/PROJECT_ID
OAUTH_ISSUER_URL=https://your-tenant.us.auth0.com

# Credentials of an application you create in that provider. The server uses
# these to call the provider's token-introspection endpoint (RFC 7662).
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret

# Optional: space-separated scopes a token must carry to be accepted.
# Leave empty to accept any valid (active) token.
OAUTH_REQUIRED_SCOPES=

# Optional: override the listen port (Render injects PORT automatically).
# PORT=8000
